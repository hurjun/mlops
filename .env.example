# ── Detector ──────────────────────────────────────────────────────────────────
API_URL=http://localhost:8000
SITE_ID=site-001

# Frame source: webcam | rtsp | file
FRAME_SOURCE=file
WEBCAM_INDEX=0
RTSP_URL=rtsp://camera.local/stream
VIDEO_FILE=samples/sample.mp4

# Inference
MODEL_PATH=yolov8n.pt
CONFIDENCE_THRESHOLD=0.4
# Process every Nth frame (5 = ~6 FPS on 30 FPS source)
INFERENCE_INTERVAL=5
# Suppress duplicate alerts for the same violation kind (seconds)
VIOLATION_COOLDOWN_SEC=10

# ── API ───────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/events.db
# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:3000

# ── Dashboard ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
